# Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/jobloom
MONGO_TEST_URI=mongodb://localhost:27017/jobloom-test

# SMS Service Configuration (Text.lk)
TEXT_LK_API_BASE_URL=https://app.text.lk/api/v3
TEXT_LK_API_TOKEN=your_api_token_here
TEXT_LK_SENDER_ID=JobLoom

# AI Job Description Generator (Cohere)
COHERE_API_KEY=your_cohere_api_key_here
COHERE_API_BASE_URL=https://api.cohere.com/v2
COHERE_MODEL=command-a-vision-07-2025

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=10

# Logging Configuration
LOG_LEVEL=debug

# CORS Configuration (Optional)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudinary (file uploads: POST /api/upload, CVs, profile images, review images)
# Dashboard: https://console.cloudinary.com/ → Account Details / API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Aliases also supported: CLOUD_NAME, API_KEY, API_SECRET
