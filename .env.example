# Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/jobloom
MONGO_TEST_URI=mongodb://localhost:27017/jobloom-test

# SMS Service Configuration (Text.lk)
TEXT_LK_API_BASE_URL=https://app.text.lk/api/v3
TEXT_LK_API_TOKEN=your_api_token_here
TEXT_LK_SENDER_ID=JobLoom

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=10

# Logging Configuration
LOG_LEVEL=debug

# CORS Configuration (Optional)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
