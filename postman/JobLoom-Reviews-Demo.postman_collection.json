    {
      "name": "✏️ Step 5 — Update Review",
      "description": "Update an existing review. Only the original reviewer can update their own review.",
      "item": [
        {
          "name": "Seeker Updates Their Review",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Review was updated', () => {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.data.review.rating).to.equal(4);",
                  "    pm.expect(res.data.review.comment).to.include('Updated:');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seekerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"comment\": \"Updated: After reflection, still a good employer. Minor payment delay but resolved quickly.\",\n  \"paymentOnTime\": 4,\n  \"communication\": 4,\n  \"wouldRecommend\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reviews/{{reviewId}}",
              "host": ["{{baseUrl}}"],
