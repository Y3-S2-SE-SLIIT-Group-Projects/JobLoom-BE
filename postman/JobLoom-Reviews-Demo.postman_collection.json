  "item": [
    {
      "name": "🔐 Step 1 — Authentication",
      "description": "Login as both users to get fresh JWT tokens. Tokens are auto-saved to collection variables `employerToken` and `seekerToken`.",
      "item": [
        {
          "name": "Login as Employer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => pm.expect(res.data).to.have.property('token'));",
                  "",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('employerToken', res.data.token);",
                  "    console.log('✅ employerToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seed.employer@jobloom.test\",\n  \"password\": \"Test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            },
            "description": "Login as the seed employer. Token auto-saved to `{{employerToken}}`."
          }
        },
        {
          "name": "Login as Job Seeker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => pm.expect(res.data).to.have.property('token'));",
                  "",
                  "if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('seekerToken', res.data.token);",
                  "    console.log('✅ seekerToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seed.seeker@jobloom.test\",\n  \"password\": \"Test1234\"\n}"
