{
  "name": "jobloom-be",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration --runInBand --passWithNoTests",
    "test:docker": "docker compose -f docker-compose.test.yml up -d && npm run test:integration; docker-compose -f docker-compose.test.yml down",
    "test:setup": "docker compose -f docker-compose.test.yml up -d",
    "test:teardown": "docker compose -f docker-compose.test.yml down",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "audit:check": "npm audit --audit-level=moderate",
    "prepare": "husky install || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Y3-S2-SE-SLIIT-Group-Projects/JobLoom-BE.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Y3-S2-SE-SLIIT-Group-Projects/JobLoom-BE/issues"
  },
  "homepage": "https://github.com/Y3-S2-SE-SLIIT-Group-Projects/JobLoom-BE#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "bcryptjs": "^3.0.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "express-validator": "^7.3.1",
    "husky": "^8.0.0",
    "jest": "^30.2.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.2.7",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
