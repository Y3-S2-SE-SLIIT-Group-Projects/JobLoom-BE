# Staging/Testing Environment Configuration
# Copy this file to .env.staging and update with real values

# Environment
NODE_ENV=test
PORT=3000

# MongoDB Atlas Configuration (STAGING DATABASE)
# Use a separate database or cluster for staging
MONGODB_URI_STAGING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jobloom-staging?retryWrites=true&w=majority

# Logging Configuration
LOG_LEVEL=debug

# Security
ALLOWED_ORIGINS_STAGING=https://staging.yourdomain.com,http://localhost:3000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=staging_jwt_secret_change_me_in_production
JWT_EXPIRATION=1d

# Rate Limiting (more lenient for testing)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Application Version
APP_VERSION=staging-latest

# Test Data Seeding
SEED_TEST_DATA=true
