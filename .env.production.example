# Production Environment Configuration
# Copy this file to .env.production and update with real values

# Environment
NODE_ENV=production
PORT=3000

# MongoDB Atlas Configuration (PRODUCTION DATABASE)
# Get this from MongoDB Atlas: Clusters > Connect > Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jobloom-prod?retryWrites=true&w=majority

# Logging Configuration
LOG_LEVEL=info

# Security
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Redis Configuration (if using external Redis service)
REDIS_URL=redis://:<password>@<host>:<port>
REDIS_PASSWORD=your_strong_redis_password_here

# JWT Configuration (for future auth implementation)
JWT_SECRET=your_very_strong_jwt_secret_here_min_32_chars
JWT_EXPIRATION=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring (for Grafana/Prometheus)
GRAFANA_PASSWORD=your_strong_grafana_password

# Application Version
APP_VERSION=1.0.0

# Calendly (OAuth & Webhooks)
CALENDLY_CLIENT_ID=your_calendly_client_id
CALENDLY_CLIENT_SECRET=your_calendly_client_secret
CALENDLY_REDIRECT_URI=https://yourdomain.com/auth/calendly/callback
CALENDLY_WEBHOOK_SIGNING_KEY=your_webhook_signing_key
